.page { padding: 16rpx 0 60rpx; }
.header { display: flex; flex-direction: column; align-items: center; padding: 40rpx 32rpx 24rpx; }
.header-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.header-name { font-size: 36rpx; font-weight: 700; }
.header-desc { font-size: 26rpx; color: var(--color-text-secondary); margin-top: 8rpx; }
.input-section { padding: 24rpx 32rpx; }
.input-label { font-size: 26rpx; font-weight: 600; color: var(--color-text-secondary); margin-bottom: 12rpx; display: block; }
.input-area { width: 100%; min-height: 120rpx; padding: 20rpx; background: #FFF; border: 2rpx solid #E5E5EA; border-radius: 16rpx; font-size: 28rpx; box-sizing: border-box; box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,.04), 0 1rpx 0 rgba(255,255,255,.8); transition: border-color .2s, box-shadow .2s; } .input-area:focus { border-color: var(--p); box-shadow: inset 0 2rpx 8rpx rgba(10,132,255,.06), 0 0 0 6rpx rgba(10,132,255,.08); }
.btn-primary { margin-top: 20rpx; display: flex; align-items: center; justify-content: center; height: 88rpx; background: var(--color-primary); color: #FFF; font-size: 28rpx; font-weight: 600; border-radius: 24rpx; border: none; }
.btn-primary:active { transform: scale(.97); }
.btn-primary[disabled] { opacity: .4; }
.result-section { padding: 24rpx 32rpx; }
.result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.result-title { font-size: 30rpx; font-weight: 600; }
.result-meta { font-size: 22rpx; color: var(--color-text-tertiary); }
.result-content { background: #FFF; border: 1rpx solid #E8E8ED; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06), 0 1rpx 0 rgba(255,255,255,.8); }
.result-text { font-size: 28rpx; line-height: 1.8; white-space: pre-wrap; }
.result-actions { display: flex; gap: 16rpx; margin-top: 20rpx; }
.btn-secondary { flex: 1; display: flex; align-items: center; justify-content: center; height: 80rpx; background: #F2F2F7; color: var(--color-text); font-size: 26rpx; border-radius: 20rpx; border: none; }
.btn-sm { flex: 1; height: 80rpx; font-size: 26rpx; border-radius: 20rpx; }

.header-row{display:flex;align-items:center;gap:16rpx}
.fav-btn{font-size:44rpx;padding:8rpx}

.example-box{background:#FFFBEB;border:1rpx solid #FDE68A;border-radius:12rpx;padding:16rpx 20rpx;margin-top:16rpx;box-shadow:0 1rpx 3rpx rgba(0,0,0,.04)}
.example-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8rpx}.example-label{font-size:24rpx;font-weight:600;color:#F59E0B}.example-copy{font-size:22rpx;color:var(--p);padding:4rpx 12rpx;background:#FFF;border-radius:8rpx}
.example-text{font-size:24rpx;color:var(--t2);line-height:1.6}
