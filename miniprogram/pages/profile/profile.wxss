.page { padding-bottom: 60rpx; }
.login-prompt { display: flex; flex-direction: column; align-items: center; padding: 120rpx 32rpx; }
.lp-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.lp-text { font-size: 28rpx; color: var(--color-text-secondary); margin-bottom: 32rpx; }
.lp-btn { width: 100%; }
.profile-card { display: flex; flex-direction: column; align-items: center; padding: 40rpx; margin-top: 24rpx; }
.p-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: #E5E5EA; }
.p-name { font-size: 36rpx; font-weight: 600; margin-top: 16rpx; }
.p-addr { font-size: 24rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.stats-row { display: flex; margin: 24rpx; background: #FFF; border-radius: 16rpx; padding: 32rpx; }
.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 48rpx; font-weight: 700; color: var(--color-primary); display: block; }
.stat-label { font-size: 24rpx; color: var(--color-text-secondary); margin-top: 4rpx; display: block; }
.stat-divider { width: 1rpx; background: #E5E5EA; }
.section-label { font-size: 26rpx; font-weight: 600; color: var(--color-text-secondary); padding: 16rpx 32rpx 8rpx; display: block; }
.my-ticket { display: flex; align-items: center; gap: 12rpx; padding: 20rpx 32rpx; background: #FFF; border-bottom: 1rpx solid #F2F2F7; }
.mt-cat { font-size: 24rpx; font-weight: 500; color: var(--color-text-secondary); min-width: 80rpx; }
.mt-title { flex: 1; font-size: 28rpx; }
.view-all { text-align: center; padding: 20rpx; color: var(--color-primary); font-size: 26rpx; }
.menu-list { margin: 24rpx; background: #FFF; border-radius: 16rpx; }
.menu-item { padding: 28rpx 32rpx; font-size: 28rpx; border-bottom: 1rpx solid #F2F2F7; }
.menu-item:last-child { border: none; }
