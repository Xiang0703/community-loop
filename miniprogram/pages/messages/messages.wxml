<view class="page">
  <view class="msg-header" wx:if="{{unreadCount > 0}}">
    <text>{{unreadCount}} 条未读</text>
    <text class="read-all" bindtap="readAll">全部已读</text>
  </view>
  <block wx:for="{{notifications}}" wx:key="id">
    <view class="msg-item {{item.is_read ? '' : 'unread'}}" data-id="{{item.ticket_id}}" bindtap="goTicket">
      <view wx:if="{{!item.is_read}}" class="unread-dot"></view>
      <view class="msg-content">
        <text class="msg-title">{{item.title}}</text>
        <text class="msg-body">{{item.content}}</text>
        <text class="msg-time">{{item.created_at}}</text>
      </view>
      <text class="msg-arrow">›</text>
    </view>
  </block>
  <view wx:if="{{notifications.length === 0}}" class="empty-state">
    <text class="empty-icon">🔔</text>
    <text class="empty-title">暂无消息</text>
  </view>
</view>
