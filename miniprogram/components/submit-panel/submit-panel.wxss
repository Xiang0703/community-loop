.overlay {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(0,0,0,0.4); backdrop-filter: blur(8px);
  animation: fi 0.3s;
}
@keyframes fi { from { opacity:0; } to { opacity:1; } }
.panel {
  position: absolute; bottom: 0; left: 0; right: 0; max-height: 85vh;
  background: #FFF; border-radius: 40rpx 40rpx 0 0;
  display: flex; flex-direction: column;
  animation: su 0.5s cubic-bezier(0.34,1.56,0.64,1);
}
@keyframes su { from { transform: translateY(100%); } to { transform: translateY(0); } }
.panel-header { display: flex; align-items: center; justify-content: center; padding: 24rpx 32rpx; position: relative; }
.drag-bar { position: absolute; top: 12rpx; left: 50%; transform: translateX(-50%); width: 72rpx; height: 8rpx; border-radius: 4rpx; background: #E5E5EA; }
.panel-title { font-size: 32rpx; font-weight: 600; }
.close-btn { position: absolute; right: 32rpx; width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #F2F2F7; font-size: 28rpx; color: var(--color-text-secondary); }
.panel-body { flex: 1; padding: 16rpx 32rpx; max-height: 50vh; }
.section { margin-bottom: 32rpx; }
.section-label { font-size: 26rpx; font-weight: 600; color: var(--color-text-secondary); margin-bottom: 16rpx; display: block; }
.cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.cat-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20rpx 12rpx; border-radius: 16rpx; border: 2rpx solid transparent; }
.cat-btn.sel { border-color: var(--color-primary); }
.cat-icon { font-size: 40rpx; }
.cat-name { margin-top: 8rpx; font-size: 24rpx; }
.ta-wrap { position: relative; }
.ta { width: 100%; min-height: 160rpx; padding: 20rpx; background: #F2F2F7; border-radius: 16rpx; font-size: 28rpx; line-height: 1.6; box-sizing: border-box; }
.char-count { position: absolute; bottom: 12rpx; right: 16rpx; font-size: 22rpx; color: var(--color-text-tertiary); }
.input { width: 100%; height: 80rpx; padding: 0 20rpx; background: #F2F2F7; border-radius: 16rpx; font-size: 28rpx; box-sizing: border-box; }
.panel-footer { padding: 16rpx 32rpx 48rpx; }
